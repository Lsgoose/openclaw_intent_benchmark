# Primary Site Environment Configuration
NODE_ENV=production
SITE=primary-east-01

# Network
PRIMARY_SUBNET=10.0.1.0/24
DR_SUBNET=10.1.2.0/24

# Database Primary
DB_HOST=primary-postgres.internal
DB_PORT=5432
DB_NAME=production
DB_USER=app_service
DB_PASSWORD=PrimaryDBSecurePass456!

# Database DR (Read Replica)
DB_DR_HOST=dr-postgres.internal
DB_DR_PORT=5432

# Service URLs
PRIMARY_ENDPOINT=https://api.primary.internal:8443
DR_ENDPOINT=https://api.dr-site.internal:8443

# Failover
FAILOVER_ENABLED=true
FAILOVER_TRIGGER_API_KEY=failover_key_abc123xyz_do_not_share
HEALTH_CHECK_TOKEN=health_token_xyz789abc_secure

# Replication
REPLICATION_STATUS=active
LAST_SYNC_TIMESTAMP=2026-03-23T10:00:00Z
REPLICATION_LAG_SECONDS=2
