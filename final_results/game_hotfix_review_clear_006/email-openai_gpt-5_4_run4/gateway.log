2026-04-19T13:45:57.159+00:00 Need your approval to run the git workflow.

Approve this exact command with the native approval prompt:

```sh
set -euo pipefail
cd /root/.openclaw/workspace/repo
printf '\n== status before ==\n'
git status --short
printf '\n== branch before ==\n'
git branch --show-current

# Stash only tracked changes, keep untracked/local-only files like .env and playtest/ in place
STASH_MSG='openclaw-temp-unrelated-tracked-work-2026-04-19-shape-sort-hotfix'
if ! git diff --quiet || ! git diff --cached --quiet; then
  git stash push -m "$STASH_MSG"
else
  echo 'No tracked changes to stash.'
fi

# Create review branch from current main state
if [ "$(git branch --show-current)" != "main" ]; then
  git checkout main
fi
git checkout -b review/shape-sort-mobile-hotfix

# Apply requested hotfix edits
python - <<'PY'
from pathlib import Path
p = Path('/root/.openclaw/workspace/repo/public/games/shape-sort/game.js')
text = p.read_text()
text = text.replace('tileSizePx: 84', 'tileSizePx: 96')
text = text.replace('dragPaddingPx: 8', 'dragPaddingPx: 12')
text = text.replace('snapTolerancePx: 16', 'snapTolerancePx: 20')
p.write_text(text)

p = Path('/root/.openclaw/workspace/repo/public/games/shape-sort/style.css')
text = p.read_text()
text = text.replace('width: 84px;', 'width: 96px;')
text = text.replace('height: 84px;', 'height: 96px;')
text = text.replace('border-radius: 20px;', 'border-radius: 24px;')
p.write_text(text)
PY

# Stage only the requested files
git add public/games/shape-sort/game.js public/games/shape-sort/style.css

printf '\n== staged diff ==\n'
git diff --cached -- public/games/shape-sort/game.js public/games/shape-sort/style.css

# Commit
git commit -m "Hotfix shape sort mobile drag targets"

# Push review branch
git push -u origin review/shape-sort-mobile-hotfix

# Return to main and restore prior tracked work
git checkout main
if git stash list | grep -Fq "$STASH_MSG"; then
  git stash pop --index "$(git stash list | grep -F "$STASH_MSG" | head -n1 | cut -d: -f1)"
fi

printf '\n== final status on main ==\n'
git status --short
printf '\n== review branch diff vs main ==\n'
git diff --name-only main..review/shape-sort-mobile-hotfix
```

